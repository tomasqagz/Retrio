{
  "appId": "io.retrio.app",
  "productName": "Retrio",
  "directories": {
    "buildResources": "public",
    "output": "dist/app"
  },
  "files": [
    "electron-main.cjs",
    "dist/main/**/*",
    "dist/preload/**/*",
    "dist/renderer/**/*"
  ],
  "publish": {
    "provider": "github",
    "owner": "tomasqagz",
    "repo": "Retrio"
  },
  "win": {
    "target": "nsis",
    "icon": "public/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "public/icon.ico",
    "uninstallerIcon": "public/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "public/icon.icns",
    "category": "public.app-category.games"
  },
  "linux": {
    "target": "AppImage",
    "category": "Game"
  }
}
